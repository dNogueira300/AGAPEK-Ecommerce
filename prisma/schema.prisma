// AGAPEK Ecommerce — esquema de datos inicial
// Regla: todas las fechas en UTC (timestamptz); conversión a America/Lima solo al mostrar.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Rol {
  ADMIN
  VENDEDOR
  TECNICO
  CLIENTE
}

enum EstadoPedido {
  PENDIENTE
  COMPROBANTE_ENVIADO
  PAGO_VALIDADO
  EN_PREPARACION
  LISTO_RECOJO
  ENVIADO
  ENTREGADO
  CANCELADO
}

enum MetodoPago {
  CONTRA_ENTREGA
  YAPE
  PLIN
  TRANSFERENCIA
  DEPOSITO
}

enum MetodoEntrega {
  DELIVERY_LOCAL
  ENVIO_NACIONAL
  RECOJO_ALMACEN
}

enum EstadoPago {
  PENDIENTE
  ENVIADO
  VALIDADO
  OBSERVADO
}

/// Perfil de usuario, enlazado 1-a-1 con auth.users de Supabase por el id (UUID).
model Perfil {
  id          String      @id @db.Uuid
  nombre      String
  dni         String?
  celular     String?
  rol         Rol         @default(CLIENTE)
  pedidos     Pedido[]
  direcciones Direccion[]
  favoritos   Producto[]  @relation("Favoritos")
  createdAt   DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime    @updatedAt @db.Timestamptz(6)
}

model Marca {
  id        String     @id @default(cuid())
  nombre    String     @unique
  slug      String     @unique
  logoUrl   String?
  aliada    Boolean    @default(false)
  productos Producto[]
}

model Categoria {
  id        String     @id @default(cuid())
  nombre    String
  slug      String     @unique
  orden     Int        @default(0)
  productos Producto[]
}

model Producto {
  id               String           @id @default(cuid())
  codigo           String           @unique
  nombre           String
  slug             String           @unique
  descripcionCorta String?
  descripcion      String?
  modoUso          String?
  precio           Decimal          @db.Decimal(10, 2)
  precioOferta     Decimal?         @db.Decimal(10, 2)
  stock            Int              @default(0)
  activo           Boolean          @default(true)
  destacado        Boolean          @default(false)
  nuevo            Boolean          @default(false)
  tipoPiel         String[]
  necesidad        String[]
  marcaId          String
  marca            Marca            @relation(fields: [marcaId], references: [id])
  categoriaId      String
  categoria        Categoria        @relation(fields: [categoriaId], references: [id])
  imagenes         ProductoImagen[]
  favoritoDe       Perfil[]         @relation("Favoritos")
  createdAt        DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime         @updatedAt @db.Timestamptz(6)

  @@index([categoriaId])
  @@index([marcaId])
}

model ProductoImagen {
  id         String   @id @default(cuid())
  productoId String
  producto   Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)
  url        String
  alt        String?
  orden      Int      @default(0)
}

model Direccion {
  id         String  @id @default(cuid())
  perfilId   String  @db.Uuid
  perfil     Perfil  @relation(fields: [perfilId], references: [id], onDelete: Cascade)
  direccion  String
  distrito   String
  referencia String?
}

model Pedido {
  id             String            @id @default(cuid())
  codigo         String            @unique
  perfilId       String            @db.Uuid
  perfil         Perfil            @relation(fields: [perfilId], references: [id])
  estado         EstadoPedido      @default(PENDIENTE)
  metodoPago     MetodoPago
  metodoEntrega  MetodoEntrega
  estadoPago     EstadoPago        @default(PENDIENTE)
  comprobanteUrl String?
  costoEnvio     Decimal           @default(0) @db.Decimal(10, 2)
  subtotal       Decimal           @db.Decimal(10, 2)
  total          Decimal           @db.Decimal(10, 2)
  observaciones  String?
  items          PedidoItem[]
  historial      PedidoHistorial[]
  createdAt      DateTime          @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime          @updatedAt @db.Timestamptz(6)

  @@index([perfilId])
  @@index([estado])
}

model PedidoItem {
  id             String   @id @default(cuid())
  pedidoId       String
  pedido         Pedido   @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  productoId     String
  nombreProducto String
  precioUnitario Decimal  @db.Decimal(10, 2)
  cantidad       Int
}

model PedidoHistorial {
  id        String       @id @default(cuid())
  pedidoId  String
  pedido    Pedido       @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  estado    EstadoPedido
  nota      String?
  autorId   String?      @db.Uuid
  createdAt DateTime     @default(now()) @db.Timestamptz(6)
}

/// Configuración clave-valor del negocio (RN-08): WhatsApp, pagos, delivery, horarios...
model Configuracion {
  clave     String   @id
  valor     Json
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
}

model Banner {
  id        String  @id @default(cuid())
  titulo    String?
  imagenUrl String
  enlace    String?
  orden     Int     @default(0)
  activo    Boolean @default(true)
}

model Testimonio {
  id     String  @id @default(cuid())
  nombre String
  texto  String
  rating Int     @default(5)
  activo Boolean @default(true)
}

model Post {
  id         String   @id @default(cuid())
  titulo     String
  slug       String   @unique
  contenido  String
  portadaUrl String?
  publicado  Boolean  @default(false)
  createdAt  DateTime @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @db.Timestamptz(6)
}
