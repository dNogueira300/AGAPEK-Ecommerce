# ============================================================
# AGAPEK Ecommerce — variables de entorno
# Copia este archivo a .env.local y completa los valores del
# proyecto Supabase de DESARROLLO (agapek-dev).
# En producción, estas variables se cargan en Vercel (agapek-prod).
# NUNCA subas .env.local al repositorio.
# ============================================================

# --- Supabase API (Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL="https://<ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon-public-key>"
# Secreto de servidor — solo backend, jamás en el cliente
SUPABASE_SERVICE_ROLE_KEY="<service-role-key>"

# --- Base de datos (Settings → Database → Connection string) ---
# Prisma 7 usa una sola URL. Para Supabase usa el "Session pooler" (puerto 5432),
# que sirve tanto para migraciones como para runtime.
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-<region>.pooler.supabase.com:5432/postgres"
# Opcional: shadow database para migraciones si Prisma no puede crearla automáticamente.
# SHADOW_DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-<region>.pooler.supabase.com:5432/postgres_shadow"

# --- App ---
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
